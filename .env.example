# Stagehand AI 自愈配置

# 1. 填入您的 Browserbase API Key (如果有)
# STAGEHAND_API_KEY=your_browserbase_api_key_here

# 2. OpenAI模型 Key (自愈能力的核心依赖)
# OPENAI_API_KEY=sk-xxxx... 

# 3. Gemini模型 Key (自愈能力的核心依赖)
# GOOGLE_API_KEY=...

# 4. Claude模型 Key (自愈能力的核心依赖)
# ANTHROPIC_API_KEY=...

# 5. DeepSeek (OpenAI 兼容模式)
STAGEHAND_API_KEY=sk-...
STAGEHAND_MODEL_NAME=deepseek-chat
STAGEHAND_API_URL=https://api.deepseek.com/v1
