{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["core/*"],
      "@projects/*": ["projects/*"]
    }
  },
  "include": ["core/**/*.ts", "projects/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules"]
}
